---
import type { HTMLAttributes } from "astro/types";
import Socials from "./Socials.astro";
import { getUi, type UiLang } from "@/i18n/ui";

const currentYear = new Date().getFullYear();

type Props = {
  noMarginTop?: boolean;
  uiLang?: UiLang;
} & HTMLAttributes<"footer">;

const {
  noMarginTop = false,
  uiLang: uiLangProp,
  class: className,
  ...attrs
} = Astro.props;

const { locale } = Astro.params;
const lang = (
  uiLangProp ??
  (locale === "ko" || locale === "ja" ? locale : "en")
) as UiLang;
const l = lang === "en" ? "" : `/${lang}`;
const L = getUi(lang);
---

<footer
  class:list={["app-layout", { "mt-auto": !noMarginTop }, className]}
  {...attrs}
>
  <div
    class:list={[
      "py-6 sm:py-4",
      "border-t border-border",
      "flex flex-col items-center justify-between sm:flex-row-reverse",
    ]}
  >
    <Socials />
    <div class="my-2 flex flex-col items-center sm:flex-row">
      <div class="flex items-center text-sm opacity-80 mb-2 sm:mb-0 sm:mr-6 gap-3">
        <a href={`${l}/about/`} class="link-subtle">{L.footerAbout}</a>
        <span>&middot;</span>
        <a href={`${l}/contact/`} class="link-subtle">{L.footerContact}</a>
        <span>&middot;</span>
        <a href={`${l}/privacy-policy/`} class="link-subtle">{L.footerPrivacy}</a>
      </div>
      <div class="flex items-center whitespace-nowrap opacity-80 text-sm">
        <span>{L.footerCopyright} &#169; {currentYear}</span>
        <span class="hidden sm:inline">&nbsp;|&nbsp;</span>
        <span>{L.footerAllRights}</span>
      </div>
    </div>
  </div>
</footer>

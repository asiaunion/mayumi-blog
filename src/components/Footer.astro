---
import type { HTMLAttributes } from "astro/types";
import { getUi, type UiLang } from "@/i18n/ui";

type Props = {
  noMarginTop?: boolean;
  uiLang?: UiLang;
} & HTMLAttributes<"footer">;

const {
  noMarginTop = false,
  uiLang: uiLangProp,
  class: className,
  ...attrs
} = Astro.props;

const currentYear = new Date().getFullYear();
const { locale } = Astro.params;
const lang = (
  uiLangProp ??
  (locale === "ko" || locale === "ja" ? locale : "ja")
) as UiLang;
const l = lang === "ja" ? "" : `/${lang}`;
const L = getUi(lang);
---

<footer
  class:list={["app-layout pb-12 pt-16 mt-20 text-center border-t border-border/50", { "mt-auto": !noMarginTop }, className]}
  {...attrs}
>
  <p class="font-serif italic text-foreground/70 mb-6 text-sm tracking-wide">
    "And into the forest I go, to lose my mind and find my soul."
  </p>
  <div class="flex justify-center space-x-8 text-xs uppercase tracking-[0.15em] text-foreground/60 mb-8 font-serif">
    <a href={`${l}/about/`} class="hover:text-accent transition-colors">{L.footerAbout}</a>
    <a href={`${l}/contact/`} class="hover:text-accent transition-colors">{L.footerContact}</a>
  </div>
  <p class="text-[0.65rem] text-foreground/40 font-sans tracking-widest uppercase">
    {L.footerCopyright} &#169; {currentYear} MAYUMI PHOEBE. All rights reserved.
  </p>
</footer>

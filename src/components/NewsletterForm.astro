---
/**
 * NewsletterForm.astro
 * Zero-JS Buttondown newsletter subscription form.
 * Renders a styled HTML <form> that posts directly to Buttondown's embed API.
 *
 * Props:
 *   variant  – "inline" (hero / footer) or "card" (post bottom)
 *   lang     – UiLang for i18n labels
 */
import { getUi, type UiLang } from "@/i18n/ui";

type Props = {
  variant?: "inline" | "card";
  lang?: UiLang;
};

const { variant = "card", lang: langProp } = Astro.props;
const { locale } = Astro.params;
const navLang = (langProp ?? locale ?? "en") as UiLang;
const L = getUi(navLang);

// Buttondown username – replace with your actual Buttondown handle
const BUTTONDOWN_USERNAME = "gsf";
const formAction = `https://buttondown.com/api/emails/embed-subscribe/${BUTTONDOWN_USERNAME}`;
---

{
  variant === "card" ? (
    <section
      id="newsletter-subscribe"
      class="mt-6 rounded-xl border border-accent/30 bg-gradient-to-br from-accent/5 to-transparent p-5"
    >
      <h2 class="text-lg font-semibold">{L.newsletterTitle}</h2>
      <p class="mt-2 text-sm leading-relaxed text-foreground/75">
        {L.newsletterBody}
      </p>
      <form
        action={formAction}
        method="post"
        target="popupwindow"
        class="mt-4 flex flex-col gap-3 sm:flex-row sm:items-end"
      >
        <div class="flex-1">
          <label for="bd-email-card" class="sr-only">
            {L.newsletterEmailLabel}
          </label>
          <input
            type="email"
            name="email"
            id="bd-email-card"
            required
            placeholder={L.newsletterPlaceholder}
            class="w-full rounded-lg border border-border bg-background px-4 py-2.5 text-sm text-foreground placeholder:text-foreground/40 focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent"
          />
        </div>
        <button
          type="submit"
          class="rounded-lg bg-accent px-5 py-2.5 text-sm font-semibold text-white transition-all hover:opacity-90 hover:shadow-md active:scale-[0.98]"
        >
          {L.newsletterCta}
        </button>
      </form>
      <p class="mt-3 text-xs text-foreground/50">{L.newsletterDisclaimer}</p>
    </section>
  ) : (
    /* inline variant for hero / footer */
    <form
      action={formAction}
      method="post"
      target="popupwindow"
      class="mt-6 flex w-full max-w-md flex-col gap-3 sm:flex-row"
      id="newsletter-inline"
    >
      <label for="bd-email-inline" class="sr-only">
        {L.newsletterEmailLabel}
      </label>
      <input
        type="email"
        name="email"
        id="bd-email-inline"
        required
        placeholder={L.newsletterPlaceholder}
        class="flex-1 rounded-full border border-border bg-background/80 px-5 py-3 text-sm text-foreground placeholder:text-foreground/40 backdrop-blur-sm focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent"
      />
      <button
        type="submit"
        class="rounded-full bg-accent px-6 py-3 text-sm font-semibold text-white shadow-lg transition-all hover:scale-105 hover:shadow-xl active:scale-[0.98]"
      >
        {L.newsletterCta}
      </button>
    </form>
  )
}

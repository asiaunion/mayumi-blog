---
import IconMoon from "@/assets/icons/IconMoon.svg";
import IconSunHigh from "@/assets/icons/IconSunHigh.svg";
import LanguageSwitcher from "./LanguageSwitcher.astro";
import { SITE } from "@/config";
import { getUi, type UiLang } from "@/i18n/ui";

type Props = { uiLang?: UiLang };

const { uiLang: uiLangProp } = Astro.props as Props;
const { pathname } = Astro.url;
const { locale } = Astro.params;
const lang = (
  uiLangProp ??
  (locale === "ko" || locale === "ja" ? locale : "ja")
) as UiLang;
const l = lang === "ja" ? "" : `/${lang}`;
const L = getUi(lang);

const currentPath =
  pathname.endsWith("/") && pathname !== "/" ? pathname.slice(0, -1) : pathname;

const normalizePath = (p: string) => {
  if (p === "/") return p;
  return p.endsWith("/") ? p.slice(0, -1) : p;
};

const isActive = (path: string) => {
  const cur = normalizePath(currentPath);
  const target = normalizePath(path);
  if (cur === target) return true;
  if (target !== "/" && cur.startsWith(`${target}/`)) return true;
  return false;
};
---

<header class="app-layout flex flex-col items-center pt-10 pb-6">
  <div class="flex w-full items-center justify-between border-b border-border/60 pb-5">
    <!-- 왼쪽: 언어 선택기 (모바일에서는 간소화) -->
    <div class="flex w-1/4 items-center justify-start max-sm:scale-90 max-sm:-ml-2">
      <LanguageSwitcher uiLang={lang} />
    </div>

    <!-- 중앙: 로고 -->
    <div class="flex w-2/4 justify-center">
      <a
        href={l || "/"}
        class="text-2xl sm:text-3xl font-extrabold tracking-[0.15em] text-foreground hover:text-accent transition-colors text-center leading-[1.1]"
        style="font-family: 'Playfair Display', serif;"
        aria-label="Mayumi Phoebe"
      >
        Mayumi<br/>Phoebe
      </a>
    </div>

    <!-- 오른쪽: 메인 메뉴 -->
    <nav class="flex w-1/4 justify-end items-center space-x-4 sm:space-x-6 text-xs sm:text-sm font-serif">
      <a href={`${l}/posts/`} class:list={["hover:text-accent uppercase tracking-widest", { "text-accent font-bold": isActive(`${l}/posts`) }]}>{L.navPosts}</a>
      <a href={`${l}/tags/`} class:list={["hover:text-accent uppercase tracking-widest", { "text-accent font-bold": isActive(`${l}/tags`) }]}>{L.navTags}</a>
      {SITE.lightAndDarkMode && (
        <button
          id="theme-btn"
          class="focus-outline relative size-8 rounded-sm p-1.5 transition-colors hover:[&>svg]:stroke-accent"
          title={L.themeToggleTitle}
          aria-label={L.themeToggleAria}
          aria-live="polite"
        >
          <IconMoon class="absolute top-[50%] left-[50%] -translate-[50%] scale-100 rotate-0 transition-all dark:scale-0 dark:-rotate-90" />
          <IconSunHigh class="absolute top-[50%] left-[50%] -translate-[50%] scale-0 rotate-90 transition-all dark:scale-100 dark:rotate-0" />
        </button>
      )}
    </nav>
  </div>
</header>

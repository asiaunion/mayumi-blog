---
import AboutLayout from "@/layouts/AboutLayout.astro";
import { getEntry, render } from "astro:content";

export function getStaticPaths() {
  return [
    { params: { locale: undefined } },
    { params: { locale: "ko" } },
    { params: { locale: "ja" } },
  ];
}

const { locale } = Astro.params;
const lang = (locale as "ko" | "ja" | undefined) ?? "en";

const entry = await getEntry("contact", lang);
if (!entry) {
  throw new Error(`Contact entry not found for locale: ${lang}`);
}

const { Content } = await render(entry);
---

<AboutLayout frontmatter={{ title: entry.data.title }} schemaType="ContactPage">
  <Content />
</AboutLayout>

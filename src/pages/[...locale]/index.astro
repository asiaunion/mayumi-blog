---
export function getStaticPaths() {
  return [
    { params: { locale: undefined } },
    { params: { locale: "ko" } },
    { params: { locale: "ja" } },
  ];
}

const { locale } = Astro.params;
const lang = locale || "en";
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Socials from "@/components/Socials.astro";
import LinkButton from "@/components/LinkButton.astro";
import Card from "@/components/Card.astro";
import getSortedPosts from "@/utils/getSortedPosts";
import IconArrowRight from "@/assets/icons/IconArrowRight.svg";
import { SITE } from "@/config";
import { SOCIALS } from "@/constants";
import { getUi, type UiLang } from "@/i18n/ui";
import { TOPIC_HUB_SLUGS, type TopicHubKey } from "@/data/topicHubs";
import NewsletterForm from "@/components/NewsletterForm.astro";

const posts = await getCollection("blog", ({ id }) => id.startsWith(`${lang}/`));
const L = getUi(lang as UiLang);

const sortedPosts = getSortedPosts(posts);
const featuredPosts = sortedPosts.filter(({ data }) => data.featured);
const recentPosts = sortedPosts.filter(({ data }) => !data.featured);
const recentHomeLimit = Math.max(SITE.postPerIndex, 6);
const hubOrder: TopicHubKey[] = [
  "urbanInvestment",
  "macroPolicy",
  "tokyoLife",
  "essay",
];
---

<Layout>
  <Header />
  <main id="main-content" data-layout="index" class="app-layout">
    <section id="hero" class="relative pt-24 pb-20 border-b border-border overflow-hidden">
      <!-- Ambient Background (Aurora) -->
      <div class="absolute inset-0 z-0 pointer-events-none">
        <div class="absolute -top-[20%] -left-[10%] w-[60%] h-[60%] rounded-full bg-accent/20 blur-[100px] animate-blob mix-blend-normal dark:mix-blend-screen"></div>
        <div class="absolute top-[10%] -right-[10%] w-[50%] h-[70%] rounded-full bg-emerald-500/15 blur-[100px] animate-blob animation-delay-2000 mix-blend-normal dark:mix-blend-screen"></div>
        <div class="absolute -bottom-[20%] left-[20%] w-[60%] h-[60%] rounded-full bg-teal-500/15 blur-[120px] animate-blob animation-delay-4000 mix-blend-normal dark:mix-blend-screen"></div>
      </div>

      <style is:inline>
        @keyframes blob {
          0% { transform: translate(0px, 0px) scale(1); }
          33% { transform: translate(30px, -50px) scale(1.1); }
          66% { transform: translate(-20px, 20px) scale(0.9); }
          100% { transform: translate(0px, 0px) scale(1); }
        }
        .animate-blob { animation: blob 15s infinite alternate ease-in-out; }
        .animation-delay-2000 { animation-delay: 2s; }
        .animation-delay-4000 { animation-delay: 4s; }
      </style>

      <div class="relative z-10 flex flex-col items-start justify-between mb-10 sm:flex-row">
        <h1 class="my-4 text-5xl font-extrabold sm:my-8 sm:text-7xl lg:text-8xl tracking-tight leading-tight">
          {L.heroTitleLine1}<br />{L.heroTitleLine2}
        </h1>
        <a
          target="_blank"
          href={`${locale ? `/${locale}` : ""}/rss.xml/`}
          class="inline-block mt-6 sm:mt-12 bg-foreground text-background px-6 py-3 rounded-full text-sm font-semibold shadow-lg hover:scale-105 hover:shadow-xl transition-all"
          aria-label={L.heroRssAria}
          title={L.heroRssTitle}
          data-cta="rss-subscribe"
          data-cta-location="home-hero"
        >
          {L.heroSubscribeRss}
        </a>
      </div>

      <div class="relative z-10 w-full max-w-2xl mb-8 backdrop-blur-[2px] bg-background/30 p-2 -ml-2 rounded-lg">
        <p class="text-xl sm:text-2xl font-medium text-foreground/90 leading-relaxed tracking-wide">
          {L.heroTagline}
        </p>
        <p class="mt-4 text-lg text-foreground/70 leading-loose">
          {L.heroDescription}
        </p>
      </div>

      {
        // only display if at least one social link is enabled
        SOCIALS.length > 0 && (
          <div class="relative z-10 mt-6 flex max-sm:flex-col sm:items-center mb-4">
            <div class="me-3 mb-1 whitespace-nowrap sm:mb-0 font-medium text-foreground/80">{L.socialLinksLabel}</div>
            <Socials trackingContext="home-hero" />
          </div>
        )
      }

      <div class="relative z-10">
        <NewsletterForm variant="inline" lang={lang as UiLang} />
        <p class="mt-3 text-center text-sm text-foreground/70">
          <a
            href={
              lang === "en"
                ? "/resources/tokyo-relocation-d90/"
                : `/${lang}/resources/tokyo-relocation-d90/`
            }
            class="underline decoration-accent/50 underline-offset-2 transition hover:text-accent"
          >
            {L.leadMagnetCta}
          </a>
        </p>
      </div>
    </section>

    {
      featuredPosts.length > 0 && (
        <section
          id="featured"
          class:list={[
            "pt-12 pb-6",
            { "border-b border-border": recentPosts.length > 0 },
          ]}
        >
          <h2 class="text-2xl font-semibold tracking-wide">{L.sectionFeatured}</h2>
          <ul>
            {featuredPosts.map(data => (
              <Card variant="h3" {...data} />
            ))}
          </ul>
        </section>
      )
    }

    {
      recentPosts.length > 0 && (
        <section id="recent-posts" class="pt-12 pb-6">
          <h2 class="text-2xl font-semibold tracking-wide">{L.sectionRecentPosts}</h2>
          <ul>
            {recentPosts.map(
              (data, index) =>
                index < recentHomeLimit && <Card variant="h3" {...data} />
            )}
          </ul>
        </section>
      )
    }

    <section id="topic-cards" class="pt-4 pb-6">
      <h2 class="text-2xl font-semibold tracking-wide">{L.sectionExploreTopics}</h2>
      <div class="mt-4 grid gap-4 sm:grid-cols-2">
        {
          hubOrder.map(key => (
            <a
              href={`${locale ? `/${locale}` : ""}/topics/#hub-${key}`}
              class="group rounded-xl border border-border bg-card p-4 transition-all duration-300 hover:-translate-y-1 hover:shadow-md hover:border-accent"
            >
              <h3 class="text-base font-semibold text-foreground">{L.topicHubs[key].title}</h3>
              <p class="mt-2 text-sm leading-relaxed text-foreground/75">
                {L.topicHubs[key].description}
              </p>
              <p class="mt-3 text-xs text-foreground/60">
                {TOPIC_HUB_SLUGS[key].length} {L.topicHubPostsLabel}
              </p>
            </a>
          ))
        }
      </div>
    </section>

    <div class="my-8 flex flex-col items-center gap-4 sm:flex-row sm:justify-center">
      <LinkButton href={`${locale ? `/${locale}` : ""}/posts/`}>
        {L.allPosts}
        <IconArrowRight class="inline-block rtl:-rotate-180" />
      </LinkButton>
      <LinkButton
        href={`${locale ? `/${locale}` : ""}/topics/`}
        class="rounded-full border border-border px-4 py-2 text-sm font-medium transition-all duration-300 hover:-translate-y-1 hover:shadow-sm hover:border-accent"
      >
        {L.topicsFromHome}
        <IconArrowRight class="inline-block rtl:-rotate-180" />
      </LinkButton>
    </div>
  </main>
  <Footer />
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    const indexLayout = (document.querySelector("#main-content") as HTMLElement)
      ?.dataset?.layout;
    if (indexLayout) {
      // Find the current locale from the html tag to set the backUrl properly
      const currentLang = document.documentElement.lang;
      sessionStorage.setItem("backUrl", currentLang === 'en' ? '/' : `/${currentLang}/`);
    }
  });
</script>

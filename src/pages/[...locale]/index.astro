---
export function getStaticPaths() {
  return [
    { params: { locale: undefined } },
    { params: { locale: "ko" } },
    { params: { locale: "ja" } },
  ];
}

const { locale } = Astro.params;
const lang = locale || "ja";
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import getSortedPosts from "@/utils/getSortedPosts";

const posts = await getCollection("blog", ({ id }) => id.startsWith(`${lang}/`));

const sortedPosts = getSortedPosts(posts);
const featuredPost = sortedPosts.find(({ data }) => data.featured) || sortedPosts[0];
const recentPosts = sortedPosts.filter(post => post !== featuredPost).slice(0, 6);
---

<Layout>
  <Header />
  <main id="main-content" data-layout="index" class="app-layout">
    {featuredPost && (
      <section id="hero" class="relative pt-12 pb-16 border-b border-border/60">
        <a href={`/${lang}/posts/${featuredPost.slug}/`} class="group block text-center">
          <div class="mb-8 w-full max-h-[65vh] overflow-hidden rounded-sm border border-border bg-muted/20">
             {/* Thumbnail Placeholder */}
             <div class="aspect-video w-full object-cover bg-accent/5"></div>
          </div>
          <p class="mb-4 text-[0.8rem] font-bold tracking-[0.2em] uppercase text-accent/80">
             {featuredPost.data.category || "Featured"}
          </p>
          <h1 class="mx-auto max-w-4xl font-serif text-5xl font-bold leading-tight tracking-normal text-foreground group-hover:text-accent transition-colors sm:text-6xl md:text-7xl">
            {featuredPost.data.title}
          </h1>
          <p class="mx-auto mt-6 max-w-2xl text-lg text-foreground/80 leading-relaxed font-serif italic">
            {featuredPost.data.description}
          </p>
        </a>
      </section>
    )}

    {recentPosts.length > 0 && (
      <section id="recent-posts" class="pt-16 pb-12">
        <div class="mb-12 text-center">
          <h2 class="inline-block border-b border-foreground/20 pb-2 font-serif text-3xl font-bold italic tracking-wide text-foreground">
            Latest Works
          </h2>
        </div>
        <ul class="grid grid-cols-1 gap-x-8 gap-y-16 sm:grid-cols-2 lg:grid-cols-3">
          {recentPosts.map((post) => (
            <li class="group">
              <a href={`/${lang}/posts/${post.slug}/`} class="block h-full">
                <div class="mb-5 aspect-[4/3] w-full overflow-hidden bg-muted/20 border border-border rounded-sm">
                  {/* Thumbnail Placeholder */}
                </div>
                <div class="flex flex-col">
                  <span class="mb-2 text-[0.65rem] font-bold uppercase tracking-widest text-accent/70">
                    {post.data.category || "Article"}
                  </span>
                  <h3 class="font-serif text-2xl font-bold leading-snug text-foreground group-hover:text-accent transition-colors">
                    {post.data.title}
                  </h3>
                  <p class="mt-3 text-sm text-foreground/70 line-clamp-3 leading-relaxed">
                    {post.data.description}
                  </p>
                </div>
              </a>
            </li>
          ))}
        </ul>
      </section>
    )}
  </main>
  <Footer />
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    const indexLayout = (document.querySelector("#main-content") as HTMLElement)
      ?.dataset?.layout;
    if (indexLayout) {
      const currentLang = document.documentElement.lang;
      sessionStorage.setItem("backUrl", currentLang === 'en' ? '/' : `/${currentLang}/`);
    }
  });
</script>
